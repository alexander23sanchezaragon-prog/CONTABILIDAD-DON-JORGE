rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn();
    }

    function isAdmin() {
      return isSignedIn() && 
             (
               request.auth.token.email.lower() == 'alexander23sanchezaragon@gmail.com' ||
               request.auth.token.email.lower() == 'alex.b19h@gmail.com'
             );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Allow test connection
    match /test/{id} {
      allow read: if true;
    }

    // Validation Blueprints (Phase 4)
    
    function isValidEmpresa(data) {
      return true; // Simplify for debugging
    }

    function isValidProducto(data) {
      return true; // Simplify for debugging
    }

    function isValidProveedor(data) {
      return true; // Simplify for debugging
    }

    function isValidCompra(data) {
      return true; // Simplify for debugging
    }

    function isValidDetalleCompra(data) {
      return true; // Simplify for debugging
    }

    function isValidVenta(data) {
      return true; // Simplify for debugging
    }

    function isValidDetalleVenta(data) {
      return true; // Simplify for debugging
    }

    function isValidCaja(data) {
      return true; // Simplify for debugging
    }

    function isValidAjusteInventario(data) {
      return true; // Simplify for debugging
    }

    // Rules for each collection
    
    match /empresa/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Temporarily allow all signed in users to write empresa for initialization
    }

    match /productos/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /proveedores/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /compras/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /detalle_compras/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /ventas/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /detalle_ventas/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /caja/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /ajustes_inventario/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /abonos_compras/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /abonos_ventas/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Empleados and pagos
    match /empleados/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /pagos_empleados/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
