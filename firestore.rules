rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn();
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'alexander23sanchezaragon@gmail.com' ||
        request.auth.token.email == 'alex.b19h@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Allow test connection
    match /test/{id} {
      allow read: if true;
    }

    // Validation Blueprints (Phase 4)
    
    function isValidEmpresa(data) {
      return data.nombre is string && data.nombre.size() <= 100 &&
             data.consecutivoCompra is number && data.consecutivoCompra >= 0 &&
             data.consecutivoVenta is number && data.consecutivoVenta >= 0;
    }

    function isValidProducto(data) {
      return data.nombre is string && data.nombre.size() <= 200 &&
             data.unidad in ['kg', 'unidad'] &&
             data.precio is number && data.precio >= 0 &&
             data.costo is number && data.costo >= 0 &&
             data.tipo in ['normal', 'produccion'] &&
             data.stock is number;
    }

    function isValidProveedor(data) {
      return data.nombre is string && data.nombre.size() <= 200 &&
             data.saldoPendiente is number;
    }

    function isValidCompra(data) {
      return data.numeroFactura is string &&
             data.fecha is timestamp &&
             data.proveedorId is string &&
             data.total is number && data.total >= 0 &&
             data.tipoPago in ['contado', 'credito'] &&
             data.estado in ['pagada', 'pendiente'];
    }

    function isValidDetalleCompra(data) {
      return data.compraId is string &&
             data.productoId is string &&
             data.cantidad is number && data.cantidad > 0 &&
             data.precioUnitario is number && data.precioUnitario >= 0 &&
             data.total is number && data.total >= 0;
    }

    function isValidVenta(data) {
      return data.numeroFactura is string &&
             data.fecha is timestamp &&
             data.clienteNombre is string &&
             data.total is number && data.total >= 0 &&
             data.tipoPago in ['contado', 'credito'] &&
             data.estado in ['pagada', 'pendiente'];
    }

    function isValidDetalleVenta(data) {
      return data.ventaId is string &&
             data.productoId is string &&
             data.cantidad is number && data.cantidad > 0 &&
             data.precioUnitario is number && data.precioUnitario >= 0 &&
             data.total is number && data.total >= 0;
    }

    function isValidCaja(data) {
      return data.fecha is timestamp &&
             data.tipo in ['entrada', 'salida'] &&
             data.monto is number && data.monto >= 0 &&
             data.concepto is string;
    }

    function isValidAjusteInventario(data) {
      return data.fecha is timestamp &&
             data.productoId is string &&
             data.cantidadAnterior is number &&
             data.cantidadNueva is number &&
             data.motivo is string;
    }

    // Rules for each collection
    
    match /empresa/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidEmpresa(incoming());
    }

    match /productos/{id} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser() && isValidProducto(incoming()) &&
                    incoming().keys().hasAll(['nombre', 'unidad', 'precio', 'costo', 'tipo', 'stock']) &&
                    incoming().keys().size() == 6;
      allow update: if isVerifiedUser() && isValidProducto(incoming()) && (
        isAdmin() ||
        incoming().diff(existing()).affectedKeys().hasAny(['stock', 'costo', 'precio'])
      );
      allow delete: if isAdmin();
    }

    match /proveedores/{id} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser() && isValidProveedor(incoming());
      allow update: if isVerifiedUser() && isValidProveedor(incoming());
      allow delete: if isAdmin();
    }

    match /compras/{id} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser() && isValidCompra(incoming()) && exists(/databases/$(database)/documents/proveedores/$(incoming().proveedorId));
      allow update: if isVerifiedUser() && isValidCompra(incoming());
      allow delete: if isAdmin();
    }

    match /detalle_compras/{id} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser() && isValidDetalleCompra(incoming()) && 
                    exists(/databases/$(database)/documents/compras/$(incoming().compraId));
      allow delete: if isAdmin();
    }

    match /ventas/{id} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser() && isValidVenta(incoming());
      allow update: if isVerifiedUser() && isValidVenta(incoming());
      allow delete: if isAdmin();
    }

    match /detalle_ventas/{id} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser() && isValidDetalleVenta(incoming()) && 
                    exists(/databases/$(database)/documents/ventas/$(incoming().ventaId));
      allow delete: if isAdmin();
    }

    match /caja/{id} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser() && isValidCaja(incoming());
      allow delete: if isAdmin();
    }

    match /ajustes_inventario/{id} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser() && isValidAjusteInventario(incoming());
    }

    match /abonos_compras/{id} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser() && incoming().monto is number && incoming().monto > 0;
    }

    match /abonos_ventas/{id} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser() && incoming().monto is number && incoming().monto > 0;
    }

    // Empleados and pagos
    match /empleados/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /pagos_empleados/{id} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser();
      allow delete: if isAdmin();
    }
  }
}
